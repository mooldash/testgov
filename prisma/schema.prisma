generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Locale {
  KK
  RU
}

enum ModuleType {
  LAW
  TEST_COLLECTION
  EXAM
}

enum TestMode {
  CLASSIC
  CLASSIC_WITH_BACK
  INSTANT_FEEDBACK
  ALL_QUESTIONS_PAGE
}

enum AccessSource {
  PURCHASE
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  role         Role     @default(USER)
  localePref   Locale   @default(RU)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attempts     Attempt[]
  examAttempts ExamAttempt[]
  access       UserAccess[]
  orders       Order[]
  reviews      Review[]
}

model Category {
  id            String  @id @default(cuid())
  slug          String  @unique
  nameKk        String
  nameRu        String
  descriptionKk String?
  descriptionRu String?
  iconKey       String?
  order         Int     @default(0)
  programs      Program[]
  extraPrograms CategoryProgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Secondary attachments: a program can be shown in additional categories
// beyond its primary `categoryId`. The primary one stays untouched (drives
// URL, breadcrumbs, SEO canonical). Used only to broaden discoverability.
model CategoryProgram {
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  order      Int      @default(0)

  createdAt DateTime @default(now())

  @@id([categoryId, programId])
  @@index([programId])
  @@index([categoryId, order])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Program {
  id            String    @id @default(cuid())
  // Optional: a program can exist without a "primary" category and only be
  // shown via CategoryProgram attachments (used for the unified demo).
  // Restrict (not Cascade) on the relation: a category with programs cannot
  // be deleted — protects against accidental wipes.
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slug          String   @unique
  nameKk        String
  nameRu        String
  descriptionKk String?
  descriptionRu String?
  priceTenge    Int      @default(0)
  durationDays  Int      @default(30)
  order         Int      @default(0)
  isPublished   Boolean  @default(true)
  isDemo        Boolean  @default(false)
  isHighlighted Boolean  @default(false)

  modules         ProgramModule[]
  tariffs         Tariff[]
  access          UserAccess[]
  orders          Order[]
  reviews         Review[]
  examAttempts    ExamAttempt[]
  extraCategories CategoryProgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Tariff {
  id           String   @id @default(cuid())
  programId    String
  program      Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  key          String   // 'econom' | 'optima' | 'vip' (custom keys allowed too)
  nameRu       String
  nameKk       String
  durationDays Int      @default(7)
  priceTenge   Int      @default(0)
  featuresRu   String[]
  featuresKk   String[]
  recommended  Boolean  @default(false)
  order        Int      @default(0)
  isPublished  Boolean  @default(true)

  accesses UserAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, key])
  @@index([programId, order])
}

model Module {
  id          String     @id @default(cuid())
  type        ModuleType @default(TEST_COLLECTION)
  isPublished Boolean    @default(true)

  // Settings used only when type=EXAM. Exam pulls random questions
  // from all TEST_COLLECTION tests of the same program.
  examQuestionsPerTest Int? // e.g. 15 (per source test)
  examTimeLimitSec     Int? // e.g. 5400 (90 min, total)
  examPassingScore     Int? // e.g. 60

  contents     ModuleContent[]
  tests        Test[]
  programs     ProgramModule[]
  examAttempts ExamAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProgramModule {
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  moduleId  String
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  order     Int     @default(0)

  createdAt DateTime @default(now())

  @@id([programId, moduleId])
  @@index([moduleId])
  @@index([programId, order])
}

model ModuleContent {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  locale   Locale
  title    String
  bodyHtml String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, locale])
}

model Test {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  locale   Locale
  title    String

  shuffleQuestions   Boolean  @default(false)
  shuffleAnswers     Boolean  @default(false)
  timeLimitSec       Int?
  maxAttempts        Int?
  requireAuth        Boolean  @default(true)
  requireAnswer      Boolean  @default(false)
  showScoreDuring    Boolean  @default(false)
  showCorrectAnswers Boolean  @default(true)
  mode               TestMode @default(INSTANT_FEEDBACK)
  emailNotifications Boolean  @default(false)
  passingScore       Int      @default(70)
  questionLimit      Int?
  isPublished        Boolean  @default(true)

  questions Question[]
  attempts  Attempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, locale])
}

model Question {
  id              String  @id @default(cuid())
  testId          String
  test            Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  order           Int     @default(0)
  textHtml        String
  explanationHtml String?
  mediaUrl        String?
  youtubeId       String?

  answers        Answer[]
  attemptAnswers AttemptAnswer[]
  examAnswers    ExamAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([testId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  textHtml   String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  attemptAnswers AttemptAnswer[]
  examAnswers    ExamAnswer[]

  @@index([questionId])
}

model Attempt {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId        String
  test          Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  score         Int?
  passed        Boolean?
  questionOrder Json

  answers AttemptAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([testId])
}

model AttemptAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerId   String?
  answer     Answer?  @relation(fields: [answerId], references: [id], onDelete: SetNull)
  isCorrect  Boolean  @default(false)
  answeredAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model UserAccess {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId       String
  program         Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  tariffId        String?
  tariff          Tariff?      @relation(fields: [tariffId], references: [id], onDelete: SetNull)
  expiresAt       DateTime
  source          AccessSource @default(MANUAL)
  paidAmountTenge Int          @default(0)

  createdAt DateTime @default(now())

  @@index([userId, programId])
  @@index([expiresAt])
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId    String
  program      Program     @relation(fields: [programId], references: [id], onDelete: Cascade)
  amountTenge  Int
  durationDays Int?
  tariffKey    String?
  status       OrderStatus @default(PENDING)
  providerName String      @default("stub")
  providerRef  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId   String
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  rating      Int      // 1..5
  text        String
  isPublished Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, programId])
  @@index([programId, isPublished, createdAt])
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  titleRu     String
  titleKk     String
  excerptRu   String    @default("")
  excerptKk   String    @default("")
  bodyRu      String    @default("")
  bodyKk      String    @default("")
  coverUrl    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, publishedAt])
}

model ExamAttempt {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  programId   String
  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  score       Int?
  passed      Boolean?

  // Snapshot of chosen questions, frozen at exam start:
  // [{ testId, testTitle, questionIds: [String] }, ...]
  chapters    Json

  answers ExamAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([moduleId])
  @@index([programId])
}

model ExamAnswer {
  id            String      @id @default(cuid())
  examAttemptId String
  examAttempt   ExamAttempt @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerId      String?
  answer        Answer?     @relation(fields: [answerId], references: [id], onDelete: SetNull)
  isCorrect     Boolean     @default(false)
  answeredAt    DateTime    @default(now())

  @@unique([examAttemptId, questionId])
  @@index([questionId])
}
